<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Approval_Status__c</field>
        <field>Profile__c</field>
        <field>Role__c</field>
        <field>User__c</field>
        <field>Payroll__c</field>
        <field>Contract_Type__c</field>
        <field>Secondary_Phone_Number__c</field>
        <field>Mail_Id__c</field>
        <field>Reporting_Manager__c</field>
        <field>Primary_Phone_Number__c</field>
        <field>TA_limit__c</field>
        <field>Vendor_Code__c</field>
        <field>Designation__c</field>
        <field>Division__c</field>
        <field>DOB__c</field>
        <field>DOJ__c</field>
        <field>Employee_Code__c</field>
        <field>User_Type__c</field>
        <field>Gross_Salary__c</field>
        <field>Headquarter__c</field>
        <field>Is_Active__c</field>
        <field>Sr_TSE_TSE__c</field>
        <field>RSM__c</field>
        <field>ASM_TSM__c</field>
        <field>Minimum_Order_value__c</field>
        <field>CTC__c</field>
        <field>DA__c</field>
        <field>Basic_Pay__c</field>
        <field>PAN__c</field>
        <field>Region__c</field>
        <field>Relieving_date__c</field>
        <field>Replaced_For__c</field>
        <field>Aadhar_Number__c</field>
        <field>Address__c</field>
        <field>Owner</field>
        <field>CreatedBy</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Employee_L1_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Employee_Level_1_Approved</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Approver_ASM__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Employee__c.Approver_ASM__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Level 1 Approval</label>
        <name>Level_1_Approval</name>
        <rejectionActions>
            <action>
                <name>Employee_L1_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Employee_Level_1_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Employee_L2_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Employee_Level_2_Approved</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Approver_RSM__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Employee__c.Approver_RSM__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Level 2 Approval</label>
        <name>Level_2_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>Employee_L2_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Employee_L2_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Employee_Level_2_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>HR_Approved</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Employee_Owner_Approver_3_HR__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>HR Approval</label>
        <name>HR_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>HR_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Employee__c.Payroll__c</field>
            <operation>equals</operation>
            <value>No</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Profile_Name__c</field>
            <operation>notEqual</operation>
            <value>HR</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Employee_Submitted</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Non Pay roll Employee Approval Process</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>true</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>2</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>

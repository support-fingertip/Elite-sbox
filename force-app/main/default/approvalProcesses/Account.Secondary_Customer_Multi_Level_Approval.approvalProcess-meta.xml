<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>creator</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Customer_Type__c</field>
        <field>Customer_Code__c</field>
        <field>Primary_Customer_Type__c</field>
        <field>Primary_Customer_Business_Type__c</field>
        <field>SAP_Customer_Code__c</field>
        <field>Customer_Status__c</field>
        <field>Owner</field>
        <field>Payment_Type__c</field>
        <field>Credit_Limit__c</field>
        <field>Email_ID__c</field>
        <field>Aadhaar_No__c</field>
        <field>Contact_Person_Name__c</field>
        <field>Contact_Person_Phone__c</field>
        <field>GST_Number__c</field>
        <field>Primary_Phone_Number__c</field>
        <field>Secondary_Phone_Number__c</field>
        <field>PAN_Number__c</field>
        <field>Owner_Email_ID__c</field>
        <field>On_Customer_Premises__c</field>
        <field>Approval_Status__c</field>
        <field>Approval_Date_Time__c</field>
        <field>Expected_Turn_over_PA__c</field>
        <field>Order_Type__c</field>
        <field>Last_Order_Date__c</field>
        <field>Last_visit_date__c</field>
        <field>Account_Holder_Name__c</field>
        <field>Bank_Name__c</field>
        <field>Branch_Name__c</field>
        <field>Account_No__c</field>
        <field>IFSC_Code__c</field>
        <field>State__c</field>
        <field>District__c</field>
        <field>Street__c</field>
        <field>Geo_Location_formula__c</field>
        <field>Pincode__c</field>
        <field>CreatedBy</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>ASM_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>ASM_Approved_Main_Status</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Customer_L1_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>ASM_TSM__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Account.ASM_TSM__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
            <criteriaItems>
                <field>Account.Approval_Status__c</field>
                <operation>notEqual</operation>
                <value>Level 1 Approved</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Level 1 Approval</label>
        <name>ASM_Approval</name>
        <rejectionActions>
            <action>
                <name>ASM_Rejected_Date</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>ASM_Rejected_Main_Approval_Status</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Customer_L1_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Activate_Customer</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Customer_L2_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>RSM_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>RSM_Approved_Main_Status</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>RSM__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Account.RSM__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
            <criteriaItems>
                <field>Account.Approval_Status__c</field>
                <operation>notEqual</operation>
                <value>Level 2 Approved</value>
            </criteriaItems>
        </entryCriteria>
        <label>Level 2 Approval</label>
        <name>RSM_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>Customer_L2_Approver_Name</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Customer_L2_Rejected_Status</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>RSM_Rejected_Date</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Account.Approval_Status__c</field>
            <operation>notEqual</operation>
            <value>Pending,Level 1 Approved,Level 2 Approved</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Customer_Type__c</field>
            <operation>equals</operation>
            <value>Secondary Customer</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Submitted_for_Approval</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Secondary Customer Multi Level Approval</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>3</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>

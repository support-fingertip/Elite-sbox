<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Profile__c</field>
        <field>Role__c</field>
        <field>User__c</field>
        <field>Payroll__c</field>
        <field>Contract_Type__c</field>
        <field>Secondary_Phone_Number__c</field>
        <field>Mail_Id__c</field>
        <field>Reporting_Manager__c</field>
        <field>Primary_Phone_Number__c</field>
        <field>TA_limit__c</field>
        <field>Vendor_Code__c</field>
        <field>Designation__c</field>
        <field>Division__c</field>
        <field>DOB__c</field>
        <field>DOJ__c</field>
        <field>Employee_Code__c</field>
        <field>User_Type__c</field>
        <field>Gross_Salary__c</field>
        <field>Headquarter__c</field>
        <field>Is_Active__c</field>
        <field>Sr_TSE_TSE__c</field>
        <field>RSM__c</field>
        <field>ASM_TSM__c</field>
        <field>Minimum_Order_value__c</field>
        <field>CTC__c</field>
        <field>DA__c</field>
        <field>Basic_Pay__c</field>
        <field>PAN__c</field>
        <field>Region__c</field>
        <field>Relieving_date__c</field>
        <field>Replaced_For__c</field>
        <field>Aadhar_Number__c</field>
        <field>Address__c</field>
        <field>Owner</field>
        <field>CreatedBy</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>Owner</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>User.Profile_Name__c</field>
                <operation>notEqual</operation>
                <value>HR</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>HR Approval</label>
        <name>HR_Approval</name>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND 2</booleanFilter>
        <criteriaItems>
            <field>Employee__c.Payroll__c</field>
            <operation>equals</operation>
            <value>No</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.Profile_Name__c</field>
            <operation>equals</operation>
            <value>HR</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>HR_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>HR_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>Non Payroll Emp HR Auto Approval</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>true</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>1</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>

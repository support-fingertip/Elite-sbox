<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Quantity_Positive</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Is_Monthly_Forecast__c, OR(ISBLANK(Forecast_Quantity__c), Forecast_Quantity__c &lt;= 0))</errorConditionFormula>
    <errorDisplayField>Forecast_Quantity__c</errorDisplayField>
    <errorMessage>Forecast Quantity must be greater than zero.</errorMessage>
</ValidationRule>

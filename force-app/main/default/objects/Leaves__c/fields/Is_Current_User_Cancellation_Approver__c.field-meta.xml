<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Is_Current_User_Cancellation_Approver__c</fullName>
    <externalId>false</externalId>
    <formula>AND(
    Approver__c = $User.Id,
    TEXT(Leave_Cancellation_Status__c) = &quot;Cancellation Approved&quot;
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Is Current User Cancellation Approver</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>

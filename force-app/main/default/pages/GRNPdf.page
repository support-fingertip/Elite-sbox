<apex:page standardController="Goods_Received_Note__c"
           extensions="GRNPdfController"
           renderAs="pdf"
           showHeader="false" standardStylesheets="false"
           applyBodyTag="false" applyHtmlTag="false">

    <html>
        <head>
            <style type="text/css">
                @page {
                    size: A4 portrait;
                    margin: 1cm;
                }
                body {
                    font-family: Arial, sans-serif;
                    color: #000;
                    font-size: 12px;
                }
                h1 {
                    text-align: center;
                    font-size: 18px;
                    margin: 0 0 12px 0;
                }
                .meta {
                    width: 100%;
                    margin-bottom: 14px;
                    font-size: 12px;
                }
                .meta td {
                    padding: 4px 0;
                }
                table.items {
                    width: 100%;
                    border-collapse: collapse;
                    font-size: 12px;
                }
                table.items th,
                table.items td {
                    border: 1px solid #333;
                    padding: 6px 8px;
                    text-align: left;
                }
                table.items th {
                    background-color: #f0f0f0;
                }
                .right { text-align: right; }
            </style>
        </head>
        <body>
            <h1>Goods Received Note</h1>

            <table class="meta">
                <tr>
                    <td><strong>GRN No:</strong> {!grn.Name}</td>
                    <td><strong>GRN Date:</strong>
                        <apex:outputText value="{0,date,dd/MM/yyyy}">
                            <apex:param value="{!grn.GRN_Date__c}"/>
                        </apex:outputText>
                    </td>
                </tr>
                <tr>
                    <td colspan="2"><strong>Invoice:</strong> {!grn.Invoice__r.Name}</td>
                </tr>
            </table>

            <apex:outputPanel rendered="{!customer != null}" layout="block">
                <table class="meta">
                    <tr><td colspan="2"><strong>Customer Details</strong></td></tr>
                    <tr>
                        <td><strong>Customer Name:</strong> {!customer.Name}</td>
                        <td><strong>SAP Code:</strong> {!customer.SAP_Customer_Code__c}</td>
                    </tr>
                    <tr>
                        <td><strong>GST Number:</strong> {!customer.GST_Number__c}</td>
                        <td><strong>State:</strong> {!customer.State__c}</td>
                    </tr>
                    <tr>
                        <td><strong>District:</strong> {!customer.District__c}</td>
                        <td><strong>Land Mark:</strong> {!customer.Land_Mark__c}</td>
                    </tr>
                    <tr>
                        <td colspan="2"><strong>Street:</strong> {!customer.Street__c}</td>
                    </tr>
                </table>
            </apex:outputPanel>

            <table class="items">
                <thead>
                    <tr>
                        <th class="right">S.No</th>
                        <th>Product</th>
                        <th class="right">Invoiced Quantity</th>
                        <th class="right">Received Saleable Qty</th>
                        <th class="right">Received Non-Saleable Qty</th>
                    </tr>
                </thead>
                <tbody>
                    <apex:variable var="rowNum" value="{!0}"/>
                    <apex:repeat value="{!items}" var="item">
                        <apex:variable var="rowNum" value="{!rowNum + 1}"/>
                        <tr>
                            <td class="right">{!rowNum}</td>
                            <td>{!item.Product__r.Name}</td>
                            <td class="right">{!item.Invoiced_Quantity__c}</td>
                            <td class="right">{!item.Received_Saleable_Quantity__c}</td>
                            <td class="right">{!item.Received_Nonsaleable_Quantity__c}</td>
                        </tr>
                    </apex:repeat>
                </tbody>
            </table>
        </body>
    </html>
</apex:page>
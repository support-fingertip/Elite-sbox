<?xml version="1.0" encoding="UTF-8"?>
<!--
  Focused manifest for the Secondary Targets / PBIS / KPI Dashboard test
  classes that are NEW or MODIFIED in this branch.

  Pre-existing test classes (SecondaryTarget_ControllerTest,
  SecondaryPBIS_ServiceTest, SecondaryPBIS_ControllerTest,
  SecondaryAchievementBatchTest, TAM_CalculationEngine_ServiceTest,
  TAM_AttendanceServiceTest, FocusedPackControllerTest) are already in
  the target org and intentionally left out of this manifest so the
  deploy doesn't fail when their production class siblings have
  diverged in the repo. Deploy those classes separately if you need
  to refresh them.

  Deploy from the repo root:
    sf project deploy start \
      --manifest manifest/package-secondary-tests.xml \
      --target-org <alias> \
      --test-level RunSpecifiedTests \
      --tests TAM_TargetCriteria_ControllerTest \
      --tests TAM_FilterEngine_ServiceTest \
      --tests SecondaryPBISSchedulerTest \
      --tests SecondaryAchievementSchedulerTest \
      --tests SecondaryKpiDashboard_ControllerTest

  Add `--dry-run` for a validation-only pass first.
-->
<Package xmlns="http://soap.sforce.com/2006/04/metadata">
    <types>
        <!-- Target Criteria CRUD (13 @AuraEnabled methods) -->
        <members>TAM_TargetCriteria_ControllerTest</members>
        <!-- WHERE-clause builder for every filtered criterion -->
        <members>TAM_FilterEngine_ServiceTest</members>
        <!-- Monthly PBIS scheduler -->
        <members>SecondaryPBISSchedulerTest</members>
        <!-- Daily achievement scheduler -->
        <members>SecondaryAchievementSchedulerTest</members>
        <!-- KPI Dashboard controller (expanded coverage) -->
        <members>SecondaryKpiDashboard_ControllerTest</members>
        <name>ApexClass</name>
    </types>
    <version>65.0</version>
</Package>

<?xml version="1.0" encoding="UTF-8"?>
<!--
  PBIS Actuals & Incentive calculation (Task 4 + the grouped-query / formula-policy
  follow-ups). Deploy with:
    sf project deploy start -x manifest/pbis_task4.xml -o <sandbox>
  Depends on Tasks 1-3 (S_D_Parameter__c with SOQL_Query__c, PBIS_Policy__c +
  PBIS_Incentive_Slab__c, PBIS_Target__c) and the org-only User field
  Monthly_Gross_Salary_INR__c. Policy is read from PBIS_Target.PBIS_Policy__c
  (a formula sourced from User.PBIS_Policy__c).
  AFTER deploy, run scripts/apex/regen_sd_parameter_soql.apex once so existing
  S&D Parameters pick up the new `uid` alias in their stored SOQL.
-->
